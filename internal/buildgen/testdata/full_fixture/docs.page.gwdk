package fixtures

@page docs.post
@route "/docs/{slug}"
@guard public

paths {
  => { slug: "getting-started" }
}

build {
  => { title: "Getting Started", tagline: "Portable Go web compiler" }
}

view {
  <main>
    <Hero title="{title}" tagline="{tagline}" />
    <p>{param("slug")}</p>
  </main>
}
