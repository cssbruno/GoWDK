package contracts

import patients "github.com/cssbruno/gowdk/examples/contracts/patients"

page contractPatients
route "/contracts/patients"
guard public

view {
  <main>
    <h1>Contracts</h1>
    <form method="post" action="/contracts/patients" g:command="patients.CreatePatient">
      <label>Name <input name="name" /></label>
      <button>Create patient</button>
    </form>
    <section g:query="patients.GetPatientPage" g:subscribe="patients.PatientNotice">
      <p>Patient query data is available through the generated JSON adapter.</p>
      <p role="status">Create a patient to receive a live presentation patch.</p>
    </section>
    <aside g:query="patients.GetPatientPage">
      <p>Patient summary is refreshed through the generated query invalidation event.</p>
    </aside>
  </main>
}
