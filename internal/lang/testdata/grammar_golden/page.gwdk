package grammar

@page grammar.demo
@route "/demo/{slug}"
@guard public
@layout root, demo
@css default page forms

paths {
  => { slug: "starter" }
}

act Submit POST "/demo/{slug}"

view {
  <main>
    <h1 .title>{slug}</h1>
    <form g:post={Submit}>
      <button>Save</button>
    </form>
  </main>
}
