{
  "page": {
    "package": "shop",
    "id": "shop.product",
    "route": "/shop/{slug}",
    "render": "action",
    "layouts": [
      "root",
      "shop"
    ],
    "guard": [
      "commerce.auth"
    ],
    "paths": true,
    "dynamicParams": [
      "slug"
    ],
    "blocks": {
      "pathsBody": "=> { slug: \"starter-kit\" }",
      "build": true,
      "buildBody": "=> { title: \"Starter Kit\" }",
      "view": true,
      "viewBody": "<main>\n    <ProductCard title=\"{title}\" />\n  </main>",
      "actions": [
        {
          "name": "Buy",
          "method": "POST",
          "route": "/shop/{slug}"
        }
      ],
      "apis": [
        "Metadata"
      ]
    }
  },
  "component": {
    "package": "shop",
    "name": "ProductCard",
    "props": [
      {
        "name": "title",
        "type": "string"
      }
    ],
    "viewBody": "<article>\n    <h1>{title}</h1>\n  </article>"
  }
}
