{
  "scopeName": "source.gwdk",
  "patterns": [
    { "include": "#comments" },
    { "include": "#annotations" },
    { "include": "#strings" },
    { "include": "#blocks" },
    { "include": "#directives" },
    { "include": "#markup" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.gwdk",
          "match": "//.*$"
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "keyword.control.annotation.gwdk",
          "match": "@(?:page|route|layout|render|guard)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.gwdk",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.gwdk",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "blocks": {
      "patterns": [
        {
          "name": "keyword.control.block.gwdk",
          "match": "\\b(?:paths|build|load|view|act|api|fragment)\\b"
        },
        {
          "name": "support.type.render-mode.gwdk",
          "match": "\\b(?:static|action|hybrid|ssr)\\b"
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "name": "entity.other.attribute-name.gwdk",
          "match": "\\bg:(?:post|target|swap)\\b"
        },
        {
          "name": "entity.other.attribute-name.css.gwdk",
          "match": "\\.[A-Za-z_][A-Za-z0-9_:-]*"
        },
        {
          "name": "entity.other.attribute-name.id.gwdk",
          "match": "#[A-Za-z_][A-Za-z0-9_:-]*"
        }
      ]
    },
    "markup": {
      "patterns": [
        {
          "name": "entity.name.tag.gwdk",
          "match": "</?[A-Za-z][A-Za-z0-9_.-]*"
        }
      ]
    }
  }
}
