package partials

page patients
route "/patients"
guard public

act Refresh POST "/patients"

fragment PatientVitals GET "/patients/{id:int}/vitals" "#patients" {
  <section id="patients">
    <p>Vitals fragment</p>
  </section>
}

view {
  <main>
    <form g:post={Refresh} g:target="#patients" g:swap="innerHTML">
      <input name="query" />
      <button>Refresh</button>
    </form>
    <section id="patients">
      <p>Initial patients</p>
    </section>
  </main>
}
