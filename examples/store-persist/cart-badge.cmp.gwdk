package shop

import ui "github.com/cssbruno/gowdk/examples/store-persist/ui"

component CartBadge

client {
  // The typed `use` binds the cart store's fields (Count) into the client scope,
  // so this component needs no separate `state` declaration of the same shape.
  use cart ui.CartState

  computed Label string {
    if Count == 0 {
      return "Cart empty"
    }
    return string(Count)
  }
}

view {
  <span class:has-items={Count > 0}>{Label}</span>
}
