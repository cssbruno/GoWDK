{
  "scopeName": "source.gwdk",
  "patterns": [
    { "include": "#comments" },
    { "include": "#metadata" },
    { "include": "#strings" },
    { "include": "#client" },
    { "include": "#blocks" },
    { "include": "#directives" },
    { "include": "#markup" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.gwdk",
          "match": "//.*$"
        }
      ]
    },
    "metadata": {
      "patterns": [
        {
          "name": "keyword.control.metadata.gwdk",
          "match": "\\b(?:page|route|title|description|canonical|image|layout|render|guard|component|css|cache|revalidate|error|wasm|asset)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.gwdk",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.gwdk",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "blocks": {
      "patterns": [
        {
          "name": "keyword.control.block.gwdk",
          "match": "\\b(?:package|import|use|paths|build|load|view|script|go|style|act|api|fragment|props|state|exports|client|emits)\\b"
        },
        {
          "name": "support.type.render-mode.gwdk",
          "match": "\\b(?:spa|action|hybrid|ssr)\\b"
        },
        {
          "name": "constant.language.http-method.gwdk",
          "match": "\\b(?:GET|POST|PUT|PATCH|DELETE)\\b"
        }
      ]
    },
    "client": {
      "patterns": [
        {
          "name": "keyword.control.client.gwdk",
          "match": "\\b(?:async|fn|computed|on|mount|destroy|effect|when|ref|let|return|await|if|else|switch|match|case|default|in|emit)\\b"
        },
        {
          "name": "support.function.builtin.gwdk",
          "match": "\\b(?:len|lower|upper|contains|string|int|float|append|remove|move|fetchJSON)\\s*(?=\\[|\\()"
        },
        {
          "name": "support.type.scalar.gwdk",
          "match": "\\b(?:string|int|float|bool)\\b"
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "name": "entity.other.attribute-name.gwdk",
          "match": "\\bg:(?:post|target|swap|ref|if|else-if|else|for|key|bind:(?:value|checked)|island)\\b"
        },
        {
          "name": "entity.other.attribute-name.gwdk",
          "match": "\\bg:on:[A-Za-z][A-Za-z0-9_-]*(?:\\.(?:prevent|stop|once|capture|debounce\\([^)]+\\)|throttle\\([^)]+\\)))*"
        },
        {
          "name": "entity.other.attribute-name.gwdk",
          "match": "\\bclass:[A-Za-z_][A-Za-z0-9_-]*"
        },
        {
          "name": "entity.other.attribute-name.gwdk",
          "match": "\\bstyle:[A-Za-z_][A-Za-z0-9_-]*(?:\\.(?:%|[A-Za-z][A-Za-z0-9_-]*))?"
        },
        {
          "name": "entity.other.attribute-name.css.gwdk",
          "match": "\\.[A-Za-z_][A-Za-z0-9_:-]*"
        },
        {
          "name": "entity.other.attribute-name.id.gwdk",
          "match": "#[A-Za-z_][A-Za-z0-9_:-]*"
        }
      ]
    },
    "markup": {
      "patterns": [
        {
          "name": "entity.name.tag.gwdk",
          "match": "</?[A-Za-z][A-Za-z0-9_.-]*"
        }
      ]
    }
  }
}
