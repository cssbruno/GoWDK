package shop

@page shop.product
@route "/shop/{slug}"
@layout root, shop
@render action
@guard commerce.auth

paths {
  => { slug: "starter-kit" }
}

build {
  => { title: "Starter Kit" }
}

act Buy POST "/shop/{slug}"

api Metadata GET "/api/products/{slug}"

view {
  <main>
    <ProductCard title="{title}" />
  </main>
}
