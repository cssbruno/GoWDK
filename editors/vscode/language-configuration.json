{
  "comments": {
    "lineComment": "//"
  },
  "brackets": [
    ["{", "}"],
    ["<", ">"],
    ["(", ")"],
    ["[", "]"]
  ],
  "autoClosingPairs": [
    ["{", "}"],
    ["<", ">"],
    ["(", ")"],
    ["[", "]"],
    ["\"", "\""]
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["<", ">"],
    ["(", ")"],
    ["[", "]"],
    ["\"", "\""]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*(view|build|load|paths|act\\s+\\w+|api(?:\\s+\\w+)?)\\s*\\{",
      "end": "^\\s*\\}"
    }
  }
}
