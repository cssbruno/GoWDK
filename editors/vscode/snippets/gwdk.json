{
  "SPA page": {
    "prefix": "page",
    "body": [
      "package ${1:app}",
      "",
      "page ${2:home}",
      "route \"${3:/}\"",
      "title \"${4:Home}\"",
      "description \"${5:Compile-first Go web output.}\"",
      "layout ${6:root}",
      "",
      "view {",
      "  ${0:<h1>GOWDK</h1>}",
      "}"
    ],
    "description": "Create a spa GOWDK page"
  },
  "SPA dynamic page with paths": {
    "prefix": "paths",
    "body": [
      "package ${1:app}",
      "",
      "page ${2:blog.post}",
      "route \"${3:/blog/{slug}}\"",
      "title \"${4:Blog post}\"",
      "description \"${5:Compile-first Go web output.}\"",
      "layout ${6:root, blog}",
      "",
      "paths {",
      "  ${7:=> { slug: \"hello\" }}",
      "}",
      "",
      "build {",
      "  ${8:// build-time data}",
      "}",
      "",
      "view {",
      "  ${0:<Article />}",
      "}"
    ],
    "description": "Create a dynamic spa page with paths"
  },
  "Action endpoint": {
    "prefix": "act",
    "body": [
      "act ${1:Submit} POST \"${2:/submit}\""
    ],
    "description": "Create an action endpoint declaration"
  },
  "API endpoint": {
    "prefix": "api",
    "body": [
      "api ${1:Status} GET \"${2:/api/status}\""
    ],
    "description": "Create an API endpoint declaration"
  },
  "Go import": {
    "prefix": "import",
    "body": [
      "import ${1:alias} \"${2:github.com/acme/app/pkg}\""
    ],
    "description": "Import a normal Go package"
  },
  "GOWDK use": {
    "prefix": "use",
    "body": [
      "use ${1:ui} \"${2:components}\""
    ],
    "description": "Import a discovered GOWDK package"
  },
  "CSS selection": {
    "prefix": "css",
    "body": [
      "css ${1|default page,default page forms,reset tokens forms,none|}"
    ],
    "description": "Select page CSS inputs"
  },
  "SSR page": {
    "prefix": "ssr",
    "body": [
      "package ${1:app}",
      "",
      "page ${2:dashboard}",
      "route \"${3:/dashboard}\"",
      "title \"${4:Dashboard}\"",
      "description \"${5:Request-time Go page output.}\"",
      "layout ${6:root, dashboard}",
      "guard ${7:auth.required}",
      "",
      "load {",
      "  ${8:// request-time data}",
      "}",
      "",
      "view {",
      "  ${0:<Dashboard />}",
      "}"
    ],
    "description": "Create an SSR page"
  },
  "Interactive component": {
    "prefix": "component",
    "body": [
      "package ${1:app}",
      "",
      "component ${2:Option}",
      "",
      "props {",
      "  ${3:Label string}",
      "}",
      "",
      "emits {",
      "  ${4:select}(label string)",
      "}",
      "",
      "client {",
      "  fn ${5:Select}() {",
      "    emit ${4:select}(Label)",
      "  }",
      "}",
      "",
      "view {",
      "  <button g:on:click={${5:Select}()}>{Label}</button>",
      "  $0",
      "}"
    ],
    "description": "Create a component with client island behavior"
  },
  "Component emits": {
    "prefix": "emits",
    "body": [
      "emits {",
      "  ${1:select}(${2:id string})",
      "}"
    ],
    "description": "Declare component events emitted by a client island"
  },
  "Async client handler": {
    "prefix": "asyncfn",
    "body": [
      "async fn ${1:Refresh}() {",
      "  ${2:Items} = await fetchJSON[${3:[]ui.Item}](\"${4:/api/items}\")",
      "}"
    ],
    "description": "Create an async client handler that fetches JSON"
  }
}
