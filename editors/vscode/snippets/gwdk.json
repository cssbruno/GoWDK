{
  "Static page": {
    "prefix": "page",
    "body": [
      "@page ${1:home}",
      "@route \"${2:/}\"",
      "@layout ${3:root}",
      "",
      "view {",
      "  ${0:<h1>GOWDK</h1>}",
      "}"
    ],
    "description": "Create a static GOWDK page"
  },
  "Static dynamic page with paths": {
    "prefix": "paths",
    "body": [
      "@page ${1:blog.post}",
      "@route \"${2:/blog/{slug}}\"",
      "@layout ${3:root, blog}",
      "@render static",
      "",
      "paths {",
      "  ${4:=> { slug: \"hello\" }}",
      "}",
      "",
      "build {",
      "  ${5:// build-time data}",
      "}",
      "",
      "view {",
      "  ${0:<Article />}",
      "}"
    ],
    "description": "Create a dynamic static page with paths"
  },
  "Action block": {
    "prefix": "act",
    "body": [
      "act ${1:submit} {",
      "  ${2:input := form ${3:Input}}",
      "  ${4:valid(input)?}",
      "  -> \"${5:/thanks}\"",
      "}"
    ],
    "description": "Create an action block"
  },
  "CSS selection": {
    "prefix": "css",
    "body": [
      "@css ${1|default page,default page forms,reset tokens forms,none|}"
    ],
    "description": "Select page CSS inputs"
  },
  "SSR page": {
    "prefix": "ssr",
    "body": [
      "@page ${1:dashboard}",
      "@route \"${2:/dashboard}\"",
      "@layout ${3:root, dashboard}",
      "@render ssr",
      "@guard ${4:auth.required}",
      "",
      "load {",
      "  ${5:// request-time data}",
      "}",
      "",
      "view {",
      "  ${0:<Dashboard />}",
      "}"
    ],
    "description": "Create an SSR page"
  },
  "Interactive component": {
    "prefix": "component",
    "body": [
      "@component ${1:Option}",
      "",
      "props {",
      "  ${2:Label string}",
      "}",
      "",
      "emits {",
      "  ${3:select}(label string)",
      "}",
      "",
      "client {",
      "  fn ${4:Select}() {",
      "    emit ${3:select}(Label)",
      "  }",
      "}",
      "",
      "view {",
      "  <button g:on:click={${4:Select}()}>{Label}</button>",
      "  $0",
      "}"
    ],
    "description": "Create a component with client island behavior"
  },
  "Component emits": {
    "prefix": "emits",
    "body": [
      "emits {",
      "  ${1:select}(${2:id string})",
      "}"
    ],
    "description": "Declare component events emitted by a client island"
  },
  "Async client handler": {
    "prefix": "asyncfn",
    "body": [
      "async fn ${1:Refresh}() {",
      "  ${2:Items} = await fetchJSON[${3:[]ui.Item}](\"${4:/api/items}\")",
      "}"
    ],
    "description": "Create an async client handler that fetches JSON"
  }
}
